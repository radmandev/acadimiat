# Environment
NODE_ENV=production
PORT=3000
HOST=0.0.0.0

# Mailchimp
MAILCHIMP_API_KEY=your_mailchimp_api_key_here
MAILCHIMP_LIST_ID=your_mailchimp_list_id_here
MAILCHIMP_WEBHOOK_KEY=your_mailchimp_webhook_key_here
VALIDATE_MAILCHIMP_SIGNATURE=true

# Bitrix24
BITRIX24_WEBHOOK_URL=https://your-company.bitrix24.com/rest/1/YOUR_TOKEN/crm.lead.add.json
BITRIX24_TIMEOUT=10000
BITRIX24_SOURCE_ID=MAILCHIMP
BITRIX24_STATUS_ID=NEW
BITRIX24_ASSIGNED_BY_ID=1

# Optional
CHECK_DUPLICATES=false
