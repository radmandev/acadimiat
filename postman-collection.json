                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"subscribe\",\n  \"fired_at\": \"2024-02-23T12:00:00Z\",\n  \"data\": {\n    \"email\": \"john.doe@example.com\",\n    \"list_id\": \"abc123def456\",\n    \"merges\": {\n      \"FNAME\": \"John\",\n      \"LNAME\": \"Doe\",\n      \"PHONE\": \"+1 (555) 123-4567\"\n    }\n  }\n}"
            },
