{
  "info": {
    "_postman_id": "mailchimp-bitrix24-integration",
    "name": "Mailchimp ↔ Bitrix24 Integration",
    "description": "Test collection for Mailchimp to Bitrix24 webhook integration",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health Checks",
      "item": [
        {
          "name": "Main Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["health"]
            },
            "description": "Check if the main server is running and healthy"
          },
          "response": []
        },
        {
          "name": "Webhook Health Check",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/webhooks/mailchimp/health",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["webhooks", "mailchimp", "health"]
            },
            "description": "Check webhook and Bitrix24 connection status"
          },
          "response": []
        }
      ]
    },
    {
