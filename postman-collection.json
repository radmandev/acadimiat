    {
      "name": "Production Mailchimp Webhook",
      "item": [
        {
          "name": "Mailchimp Webhook (Production)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              },
              {
                "key": "X-Mailchimp-Hook-Signature",
                "value": "sha256=YOUR_WEBHOOK_SIGNATURE_HERE",
                "type": "text",
                "description": "Get this from Mailchimp webhook configuration"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"subscribe\",\n  \"fired_at\": \"2024-02-23T12:00:00Z\",\n  \"data\": {\n    \"email\": \"real@mailchimp.com\",\n    \"list_id\": \"abc123def456\",\n    \"merges\": {\n      \"FNAME\": \"Real\",\n      \"LNAME\": \"Subscriber\",\n      \"PHONE\": \"+1 (555) 987-6543\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "https://api.yourdomain.com/webhooks/mailchimp",
              "protocol": "https",
              "host": ["api", "yourdomain", "com"],
              "path": ["webhooks", "mailchimp"]
            },
            "description": "This is what Mailchimp will send to your production webhook URL. Update the domain and signature header."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Error Cases",
      "item": [
