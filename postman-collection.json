                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"unsubscribe\",\n  \"data\": {\n    \"email\": \"test@example.com\",\n    \"merges\": {\n      \"FNAME\": \"Test\",\n      \"LNAME\": \"User\"\n    }\n  }\n}"
            },
            "url": {
              "raw": "http://localhost:3000/webhooks/mailchimp/test",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["webhooks", "mailchimp", "test"]
            },
            "description": "Test with non-subscribe event type (should be ignored)"
          },
          "response": []
        },
        {
          "name": "404 - Not Found",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "http://localhost:3000/nonexistent",
              "protocol": "http",
              "host": ["localhost"],
              "port": "3000",
              "path": ["nonexistent"]
            },
            "description": "Test 404 error handling"
          },
          "response": []
        }
      ]
    }
